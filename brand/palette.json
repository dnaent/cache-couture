{
  "version": "1.0.0",
  "updated": "2026-05-19",
  "source": "CLAUDE.md §2.3",
  "rules": {
    "monochrome_only": true,
    "spot_colour_allowed_when": "asset is tied to a phygital/metaverse moment",

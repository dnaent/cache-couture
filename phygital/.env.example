# Caché phygital service — environment template. Copy to .env and fill in.
# Never commit the real .env (see repo .gitignore).

# --- Shopify ---
# Admin API: Shopify Admin → Settings → Apps → Develop apps → (your app) → API credentials.
SHOPIFY_STORE_DOMAIN=hiddencache.co.uk
SHOPIFY_MYSHOPIFY_DOMAIN=hiddencache.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=
# Webhook signing secret — used to verify orders/paid HMAC. Shopify shows this when
# you create the webhook (Settings → Notifications → Webhooks, or via Admin API).
SHOPIFY_WEBHOOK_SECRET=

# --- NFT mint (phygital protocol, CLAUDE.md §5) ---
# 1:1 tethered NFT auto-mints to buyer wallet at purchase. Fill once chain/contract chosen.
NFT_CHAIN=
NFT_CONTRACT_ADDRESS=
NFT_MINTER_PRIVATE_KEY=
NFT_RPC_URL=

# --- Alibaba supplier (fulfillment) ---
# Left blank: supplier not yet locked (2026-06-26). Recommended route is the official
# Alibaba.com Dropshipping app for order sync; these are only for a future custom API path.
ALIBABA_API_BASE=
ALIBABA_API_KEY=
ALIBABA_API_SECRET=

# --- Persistence (SKU ↔ tokenId ↔ wallet mapping) ---
# Firestore in GCP project cache-couture. Leave unset to use the in-memory dev store.
GCP_PROJECT=cache-couture
FIRESTORE_COLLECTION=phygital_tethers
